ARCHE_PRIVACY_SALT=replace-with-strong-random-salt
ANTHROPIC_API_KEY=replace-with-your-anthropic-key
GROQ_API_KEY=replace-with-your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
SUPABASE_PROJECT_REF=replace-with-your-project-ref
SUPABASE_DB_HOST=db.replace-with-your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=replace-with-your-db-password
SUPABASE_SSLMODE=require
DATABASE_URL=postgresql://postgres:replace-with-your-db-password@db.replace-with-your-project-ref.supabase.co:5432/postgres?sslmode=require
